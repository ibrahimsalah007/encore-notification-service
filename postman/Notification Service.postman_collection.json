{
  "info": {
    "name": "Notification Service",
    "_postman_id": "d5e2e4d4-9b4d-4d88-8de0-1f4e8f4a7b11",
    "description": "Postman collection for the Notification Service assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ibrahim Salah\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Creates a new user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "    pm.collectionVariables.set('userId', jsonData.id);",
                  "    pm.environment.set('userId', jsonData.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?limit=20&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Lists users with pagination."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Create Notification - In App",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"channel\": \"in_app\",\n  \"title\": \"Welcome\",\n  \"body\": \"Welcome to the platform\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "description": "Creates an in-app notification for the selected user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.notification && jsonData.notification.id) {",
                  "    pm.collectionVariables.set('notificationId', jsonData.notification.id);",
                  "    pm.environment.set('notificationId', jsonData.notification.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Notification - Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"channel\": \"email\",\n  \"title\": \"Email Welcome\",\n  \"body\": \"This is a simulated email notification\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "description": "Creates an email notification for the selected user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.notification && jsonData.notification.id) {",
                  "    pm.collectionVariables.set('notificationId', jsonData.notification.id);",
                  "    pm.environment.set('notificationId', jsonData.notification.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List User Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/notifications?limit=20&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}",
                "notifications"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Lists all notifications for a user."
          }
        },
        {
          "name": "List Unread Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/notifications/unread?limit=20&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}",
                "notifications",
                "unread"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Lists unread notifications for a user."
          }
        },
        {
          "name": "Mark Notification As Read",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/notifications/{{notificationId}}/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications",
                "{{notificationId}}",
                "read"
              ]
            },
            "description": "Marks the selected notification as read."
          }
        }
      ]
    }
  ]
}